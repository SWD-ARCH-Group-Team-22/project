@startuml Freeplane_C4_Container_Diagram
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Freeplane Software Container Diagram

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

skinparam wrapWidth 200
skinparam maxMessageSize 200

Container_Boundary(freeplane_app, "Freeplane") {
    Container(framework,   "Freeplane Framework Plugin",   "Java Application", "Backbone of the software application")
    Container(freeplane,   "Freeplane Core",               "Java application",  "Central core of the system, it owns the inner business logic of the software")
    Container(api,         "Freeplane API",                "Java Application",  "Provides encapsulation for basic Freeplane features to be implemented by user-defined scripts")
    Container(ai,          "Freeplane AI",                 "Java application",  "Plugin that enables the communication between user and LLM tools within the software workstation")
    Container(openmaps,    "Freeplane Openmaps Plugin",    "Java Application",  "Geographical data and visualization support")
    Container(bug,         "Freeplane Bug Report",         "Java Application",  "Bug report system")
    Container(script,      "Freeplane Plugin Script",      "Java Application",  "Plugin in charge of managing the Groovy scripting engine")
    Container(formula,     "Freeplane Plugin Formula",     "Java Application",  "Plugin in charge of handling user-defined formulas, to be rendered in a Groovy Script")
    Container(markdown,    "Freeplane Markdown Plugin",    "Java Application",  "Support for markdown format")
    Container(latex,       "Freeplane LaTeX Plugin",       "Java Application",  "It provides support for LaTeX scripting language within the workstation")
    Container(svg,         "Freeplane SVG Plugin",         "Java Application",  "Graphic support for non-raster images")
    Container(syntax,      "Freeplane JSyntaxPane Plugin", "Java Application",  "Enhanced text readability features")
    Container(codeexplorer,"Freeplane CodeExplorer Plugin","Java Application",  "Different mode within the software that provides advanced code analysis features")
    Container(debughelper, "Freeplane Plugin Debughelper", "Java application",  "Plugin in charge of setting the debugging environment up")
}

System_Ext(markdj, "Markdj", "Java library for rendering marjdown")
System_Ext(jsyntaxpane, "JSyntaxPane", "Java library for graphic ui settings over text in Java environments")
System_Ext(latexmath, "JLatexMath", "Java library for rendering LaTeX")
System_Ext(llm, "LangChain 4j", "Java library for adding LLM support")
System_Ext(groovy, "Groovy", "Groovy scripting engine")
System_Ext(ivy, "Apache Ivy", "It supports script execution")
System_Ext(batik, "Apache Batik", "Svg Rendering")
System_Ext(fop, "Apache FOP", "SVG to PDF transcoding")
System_Ext(mapviewer, "JMapViewer", "Java library supporting OpenStreetMap data visualization")
System_Ext(archunit, "ArchUnit", "Java library to test code")
System_Ext(jgrapht, "JGraphT", "Java library to explore graphs")
System_Ext(assertjcore, "AssertJCore", "Java library for testing assertions")

' == external systems == '

Rel_D(markdown, markdj, "Relies on")
Rel_D(ai, markdj, "Relies on")
Rel_D(syntax, jsyntaxpane, "Relies on")
Rel_D(latex, latexmath, "Relies on")
Rel_D(ai, llm, "Relies on")
Rel_D(script, groovy, "Runs scripts on")
Rel_D(script, ivy, "resolves dependencies thanks to")
Rel_D(svg, batik, "Renders svg images relying on")
Rel_D(svg, fop, "Exports files relying on")
Rel_D(openmaps, mapviewer, "Renders map in nodes thanks to")
Rel_D(codeexplorer, archunit, "Tests architectural flaws")
Rel_D(codeexplorer, jgrapht, "Resolves class-dependencies through")
Rel_D(codeexplorer, assertjcore, "Improves testing with")
' == hint di posizionamento verticale ==
Lay_D(framework, freeplane)
Lay_D(freeplane, api)
Lay_D(freeplane, script)
Lay_D(freeplane, svg)
Lay_D(api, debughelper)
Lay_D(freeplane, codeexplorer)

' == hint di posizionamento orizzontale ==
Lay_R(freeplane, ai)
Lay_R(freeplane, openmaps)
Lay_R(freeplane, bug)
Lay_R(script, formula)
Lay_R(script, markdown)
Lay_R(script, latex)
Lay_R(script, syntax)

Rel(codeexplorer, freeplane, "Registers a new modality within the core application", "JAVA METHOD CALL")


' === Framework → Core ===
Rel_D(framework, api,      "Loads to make its instances global for anybody", "JAVA METHOD CALL")
Rel_D(freeplane, api,      "Loads", "JAVA METHOD CALL")

' === Core → Plugin ===
Rel_D(freeplane, script,   "Delegates script execution",                          "JAVA METHOD CALL")
Rel_D(freeplane, markdown, "Sends markdown text to be rendered",                  "JAVA METHOD CALL")
Rel_D(freeplane, latex,    "Delegates LaTeX rendering to",                        "JAVA METHOD CALL")
Rel_D(freeplane, svg,      "Delegates SVG graphic rendering and exporting to",    "JAVA METHOD CALL")
Rel_D(freeplane, bug,      "Sends data about errors to",                          "JAVA METHOD CALL")

' === Plugin → Core (registrazione UI) ===
Rel_U(ai,      freeplane, "Registers in the UI and manipulates nodes",                          "JAVA METHOD CALL")
Rel_U(openmaps, freeplane, "Registers in the UI and manipulates nodes to show geographical data", "JAVA METHOD CALL")

' === Scripting ===
Rel_D(formula, script, "Sends formula to be executed", "JAVA METHOD CALL")

' === Syntax → rendering ===
Rel(syntax, script,   "Renders graphical features for text", "JAVA METHOD CALL")
Rel(syntax, markdown, "Renders graphical features for text", "JAVA METHOD CALL")
Rel(syntax, latex,    "Renders graphical features for text", "JAVA METHOD CALL")

' === Debug Helper (isolato in basso) ===
Rel(debughelper, freeplane,  "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, framework,  "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, api,        "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, ai,         "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, script,     "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, formula,    "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, syntax,     "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, markdown,   "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, svg,        "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, latex,      "Injects debug environment variables to", "JAVA METHOD CALL")
Rel(debughelper, openmaps,   "Injects debug environment variables to", "JAVA METHOD CALL")

@enduml