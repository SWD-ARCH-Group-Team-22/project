@startuml 
title Outline subsystem domain - code dependencies

left to right direction
set namespaceSeparator none

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 135
skinparam ranksep 100
skinparam ArrowFontSize 10
skinparam NoteFontSize 11
skinparam LegendFontSize 11

hide empty members

package "org.freeplane" as Freeplane {

  package "view/swing/map/outline" as OutlinePkg {
    class MapAwareOutlinePane
    class OutlinePane
    class BreadcrumbPanel
    class ScrollableTreePanel
    class OutlineController
    class BlockPanel
    class OutlineViewport

    ' layout guide: keep outline domain wide and central
    MapAwareOutlinePane -[hidden]right- OutlinePane
    OutlinePane -[hidden]right- ScrollableTreePanel
    ScrollableTreePanel -[hidden]right- BlockPanel
    ScrollableTreePanel -[hidden]down- OutlineViewport
    BreadcrumbPanel -[hidden]down- OutlinePane
    BreadcrumbPanel -[hidden]right- OutlineController
    OutlineController -[hidden]down- ScrollableTreePanel
  }

  package "view/swing/map" as MapPkg {
    class MapView
    class NodeView
  }

  package "features/map" as FeaturesPkg {
    class NodeModel
  }

  ' keep external map/model packages on the right
  OutlinePkg -[hidden]right- MapPkg
  MapPkg -[hidden]down- FeaturesPkg
}

class "External concerns\nlisteners, filters,\nbookmarks, toolbar/menu" as ExternalConcerns

MapAwareOutlinePane -[hidden]up- ExternalConcerns

' inheritance
MapAwareOutlinePane --|> OutlinePane : extends

' main structural dependencies
OutlinePane -left-> BreadcrumbPanel : creates and\ncoordinates
OutlinePane -right-> ScrollableTreePanel : creates and\ncoordinates
OutlinePane -down-> OutlineController : creates and\ncoordinates

BreadcrumbPanel -up-> OutlineController : delegates selection\nand expansion
OutlineController --> ScrollableTreePanel : controls

ScrollableTreePanel --> BlockPanel : delegates\nvisible groups
BlockPanel --> ScrollableTreePanel : returns user\nactions

ScrollableTreePanel -right-> OutlineViewport : creates and\nmanages scrolling

' cross-domain dependencies
MapAwareOutlinePane -[#gray,dashed]-> MapView : sync
MapAwareOutlinePane -[#gray,dashed]-> NodeView : selection
MapAwareOutlinePane -[#gray,dashed]-> NodeModel : data
MapAwareOutlinePane -[#gray,dashed]-> ExternalConcerns : uses

note top of ExternalConcerns
Grouped external concerns show that the outline
must react to map listeners, filters, bookmarks
and toolbar/menu actions.
end note

legend bottom right
  <b>Line styles</b>
  Hollow triangle arrow: inheritance / extension
  Solid black line: main structural / creational dependency
  Dashed gray line: secondary / cross-domain dependency
endlegend

